BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32

# Comma-separated: every origin you use (Better Auth trusted origins + CORS). Example LAN access:
# CLIENT_URL=http://localhost:5173,http://192.168.1.20:5173
CLIENT_URL=http://localhost:5173

# Optional. Public origin where the app is served (session cookies use http vs https from this). Defaults to first CLIENT_URL.
# Set when the canonical URL is not first in CLIENT_URL, e.g. BETTER_AUTH_URL=http://192.168.1.20:5173
# BETTER_AUTH_URL=

# Web Application Environment Variables
# These are embedded at build time by Vite

# Backend URL
# Leave empty for same-origin requests (recommended when using Nginx proxy)
# Or set to the full backend URL if accessing directly
VITE_BACKEND_URL=

